{
    "type": "container",
    "id": "card",
    "style": {
        "width": "100%",
        "height": "100%",
        "flexDirection": "column",
        "padding": 16,
        "backgroundColor": "#FFFFFF",
        "cornerRadius": 12
    },
    "events": {
        "onTap": "app://card_tap?id=${card.id}"
    },
    "children": [
        {
            "type": "text",
            "id": "title",
            "style": {
                "width": "100%",
                "height": "auto",
                "fontSize": 24,
                "fontWeight": "bold",
                "textColor": "#333333"
            },
            "props": {
                "text": "${card.title}"
            }
        },
        {
            "type": "text",
            "id": "subtitle",
            "style": {
                "width": "100%",
                "height": "auto",
                "marginTop": 8,
                "fontSize": 14,
                "textColor": "#666666"
            },
            "props": {
                "text": "${card.subtitle}"
            }
        },
        {
            "type": "container",
            "id": "spacer",
            "style": {
                "flexGrow": 1
            }
        },
        {
            "type": "button",
            "id": "action_btn",
            "style": {
                "width": "100%",
                "height": 44,
                "backgroundColor": "#007AFF",
                "cornerRadius": 8,
                "textColor": "#FFFFFF",
                "fontWeight": "500"
            },
            "props": {
                "title": "${card.buttonText}"
            },
            "events": {
                "onTap": {
                    "url": "app://detail",
                    "params": {
                        "cardId": "${card.id}",
                        "cardTitle": "${card.title}",
                        "source": "basic_card"
                    }
                }
            }
        }
    ]
}
